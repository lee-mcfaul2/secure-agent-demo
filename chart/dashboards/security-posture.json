{
  "uid": "ai-sec-posture",
  "title": "AI Security — Security Posture",
  "tags": ["ai-security", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "LLM Guard enabled",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "gateway_llm_guard_enabled", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ENABLED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DISABLED", "color": "red" } } }
          ]
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2, "type": "stat", "title": "Scans blocked (1h)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(increase(llm_guard_scanner_hits_total[1h]))", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3, "type": "stat", "title": "Redactions (1h)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "sum(increase(gateway_redactions_total[1h]))", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4, "type": "timeseries", "title": "LLM Guard hits by scanner",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum by (scanner, direction) (rate(llm_guard_scanner_hits_total[1m]))",
        "refId": "A", "legendFormat": "{{scanner}} ({{direction}})"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5, "type": "timeseries", "title": "OPA denials per MCP",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "sum by (mcp) (rate(gateway_tool_calls_total{outcome=\"opa_deny\"}[1m]))",
        "refId": "A", "legendFormat": "{{mcp}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6, "type": "piechart", "title": "LLM Guard verdict distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "sum by (verdict) (increase(llm_guard_scans_total[1h]))",
        "refId": "A", "legendFormat": "{{verdict}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7, "type": "stat", "title": "Sandbox schema mismatches (1h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "sum(increase(sandbox_response_schema_mismatch_total[1h]))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}
